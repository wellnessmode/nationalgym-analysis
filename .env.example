# 실제 값을 채워서 .env 로 저장. .env 는 절대 커밋 금지(.gitignore 처리됨)
#
# 1) Supabase
#    위치: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY  # Edge Function 전용. 클라이언트 노출 금지.

# 2) Supabase DB 직결 URL (마이그레이션 자동 적용 스크립트용)
#    위치: Supabase Dashboard > Project Settings > Database > Connection string > URI (transaction)
#    포맷: postgresql://postgres.PROJECT:PASSWORD@aws-0-...:6543/postgres
SUPABASE_DB_URL=

# 3) Firebase Web Config (FCM Web Push)
#    위치: Firebase Console > 프로젝트 설정 > 일반 > 내 앱(웹)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# 4) FCM Web Push VAPID Public Key
#    위치: Firebase Console > 프로젝트 설정 > Cloud Messaging > Web push certificates
FIREBASE_VAPID_PUBLIC_KEY=
